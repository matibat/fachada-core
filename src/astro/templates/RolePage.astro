---
/**
 * RolePage — core template for role-specific subsection pages.
 *
 * Renders a full role presentation driven entirely by siteConfig.roles.
 * Apps configure which role and layout style via RolePageData in their
 * siteTree subsection definition — no app-specific .astro required.
 *
 * Supports two hero styles:
 *   "split"       — 60vh two-column layout (engineering / technical feel)
 *   "atmospheric" — full-viewport centred layout (artistic / ambient feel)
 */
import type { RolePageData } from "@fachada/core";
import type { PageMeta } from "@fachada/core";
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StructuredData from "../components/StructuredData.astro";
import Projects from "../widgets/Projects.astro";
import Contact from "../widgets/Contact.astro";
import { siteConfig } from "../config";

interface Props {
  meta: PageMeta;
  data: RolePageData;
}

const { meta, data } = Astro.props;

const {
  roleId,
  heroStyle = "split",
  showBreadcrumb = true,
  contactMessage,
  contactLayout = "split",
  projectsLayout = "grid-3",
  galleryLabel,
  skillsLabel,
  bioLabel,
  scrollCta = "↓ Ver trabajo",
  availabilityLine,
} = data;

const role = siteConfig.roles.find((r) => r.id === roleId);
if (!role) {
  return new Response(`Role "${roleId}" not found in siteConfig`, { status: 404 });
}

const defaultContactMessage =
  contactLayout === "centered"
    ? `¿Te interesa algo? Escribime y lo charlamos.`
    : `Disponible para proyectos. Hablemos.`;

const resolvedGalleryLabel = galleryLabel ?? (heroStyle === "atmospheric" ? "Trabajos" : "Proyectos");
const resolvedSkillsLabel = skillsLabel ?? (heroStyle === "atmospheric" ? "Técnicas" : "Habilidades");
const resolvedBioLabel = bioLabel ?? "Mi enfoque";

const resolvedContactMessage = contactMessage ?? defaultContactMessage;

const personSchema = {
  name: siteConfig.name,
  url: `${siteConfig.url}${meta.path}`,
  jobTitle: role.title,
  description: role.description,
  sameAs: [
    siteConfig.social.github,
    siteConfig.social.linkedin,
    siteConfig.social.twitter,
    siteConfig.social.instagram,
  ].filter(Boolean),
};
---

<BaseLayout title={meta.title} description={meta.description}>
  <StructuredData type="Person" data={personSchema} />
  <Header currentPath={meta.path} />

  <main data-page={roleId} data-hero-style={heroStyle}>

    {showBreadcrumb && (
      <div class="rp-breadcrumb">
        <div class="max-w-6xl mx-auto px-4">
          <nav aria-label="Breadcrumb">
            <a href="/" class="rp-breadcrumb-link">← Home</a>
            <span class="rp-breadcrumb-sep" aria-hidden="true">/</span>
            <span class="rp-breadcrumb-current">{role.title}</span>
          </nav>
        </div>
      </div>
    )}

    <!-- ── SPLIT HERO (technical / engineering style) ─────────────────── -->
    {heroStyle === "split" && (
      <section class="rp-hero rp-hero--split" data-testid={`${roleId}-hero`}>
        <div class="max-w-6xl mx-auto px-4 w-full rp-hero-grid">
          <div class="rp-hero-identity">
            <p class="rp-overline">{role.title}</p>
            <h1 class="rp-headline">{role.specialties.slice(0, 3).join(", ")}.</h1>
            <div class="rp-specialties" role="list" aria-label="Core specialties">
              {role.specialties.map((s) => (
                <span class="rp-tag" role="listitem">{s}</span>
              ))}
            </div>
          </div>
          <div class="rp-hero-content">
            <p class="rp-description">{role.description}</p>
            {(siteConfig.social.whatsapp || siteConfig.social.email) && (
              <a
                href={siteConfig.social.whatsapp ?? `mailto:${siteConfig.social.email}`}
                class="rp-cta-btn"
                target={siteConfig.social.whatsapp ? '_blank' : undefined}
                rel={siteConfig.social.whatsapp ? 'noopener noreferrer' : undefined}
              >
                {siteConfig.social.whatsapp ? 'WhatsApp' : 'Email me'}
              </a>
            )}
            {availabilityLine && (
              <p class="rp-availability">{availabilityLine}</p>
            )}
          </div>
        </div>
      </section>
    )}

    <!-- ── ATMOSPHERIC HERO (artistic / ambient style) ────────────────── -->
    {heroStyle === "atmospheric" && (
      <section class="rp-hero rp-hero--atmospheric" data-testid={`${roleId}-hero`}>
        <div class="rp-atm-inner">
          <p class="rp-overline">{role.title}</p>
          <h1 class="rp-atm-headline">
            {role.specialties.map((s, i) => (
              <Fragment>{s}{i < role.specialties.length - 1 ? "." : "."}<br /></Fragment>
            ))}
          </h1>
          {role.description && (
            <p class="rp-atm-subheading">{role.description}</p>
          )}
          <a href="#gallery" class="rp-atm-scroll-cta" aria-label="Scroll to work">
            {scrollCta}
          </a>
        </div>
      </section>
    )}

    <!-- ── MEAT 1: Artist statement (atmospheric only) ────────────────── -->
    {heroStyle === "atmospheric" && role.about && (
      <section class="rp-statement" data-testid={`${roleId}-statement`}>
        <div class="max-w-xl mx-auto px-4 text-center">
          <div class="rp-statement-body">
            {role.about.paragraphs.map((para) => (
              <p class="rp-statement-para">{para}</p>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ── PROJECTS ───────────────────────────────────────────────────── -->
    <section
      id="gallery"
      class:list={["rp-section", { "rp-section--alt": heroStyle === "atmospheric" }]}
      data-testid={`${roleId}-projects`}
    >
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="rp-section-heading">
          {resolvedGalleryLabel}
        </h2>
        <Projects layout={projectsLayout} filterRoles={[roleId]} />
      </div>
    </section>

    <!-- ── SKILLS ─────────────────────────────────────────────────────── -->
    {role.skills && (
      <section
        class:list={["rp-section", { "rp-section--alt": heroStyle === "split" }]}
        data-testid={`${roleId}-skills`}
      >
        <div class="max-w-6xl mx-auto px-4">
          <h2 class="rp-section-heading">
            {resolvedSkillsLabel}
          </h2>
          <div class="rp-skills-grid">
            {role.skills.map((category) => (
              <div class="rp-skill-card">
                <h3 class="rp-skill-heading">{category.name}</h3>
                {heroStyle === "split" ? (
                  <div class="rp-skill-tags" role="list">
                    {category.skills.map((skill) => (
                      <span class="rp-skill-tag" role="listitem">{skill}</span>
                    ))}
                  </div>
                ) : (
                  <ul class="rp-skill-list" role="list">
                    {category.skills.map((skill) => (
                      <li class="rp-skill-item" role="listitem">{skill}</li>
                    ))}
                  </ul>
                )}
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ── PROCESS / BIO (split only) ────────────────────────────────── -->
    {heroStyle === "split" && role.about && (
      <section class="rp-section" data-testid={`${roleId}-process`}>
        <div class="max-w-3xl mx-auto px-4">
          <h2 class="rp-section-heading">{resolvedBioLabel}</h2>
          <div class="rp-process-body">
            {role.about.paragraphs.map((para) => (
              <p class="rp-process-para">{para}</p>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ── CTA ───────────────────────────────────────────────────────── -->
    <Contact layout={contactLayout} message={resolvedContactMessage} />

  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Breadcrumb ────────────────────────────────────────────── */
  .rp-breadcrumb {
    padding: 1.25rem 0 0;
    font-size: 0.875rem;
  }
  .rp-breadcrumb-link {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--transition);
  }
  .rp-breadcrumb-link:hover { color: var(--accent); }
  .rp-breadcrumb-sep { color: var(--text-secondary); margin: 0 0.5rem; }
  .rp-breadcrumb-current { color: var(--text-primary); }

  /* ── Split Hero ────────────────────────────────────────────── */
  .rp-hero--split {
    min-height: 60vh;
    display: flex;
    align-items: center;
    padding: 4rem 0;
  }
  .rp-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 768px) {
    .rp-hero-grid {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }
    .rp-hero-identity {
      border-right: 1px solid var(--border);
      padding-right: 5rem;
    }
  }

  /* ── Atmospheric Hero ──────────────────────────────────────── */
  .rp-hero--atmospheric {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 1rem;
    text-align: center;
    background: radial-gradient(
      ellipse 80% 60% at 50% 40%,
      var(--bg-secondary) 0%,
      var(--bg-primary) 100%
    );
  }
  .rp-atm-inner {
    max-width: 54rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }
  .rp-atm-headline {
    font-family: var(--font-heading, serif);
    font-weight: var(--heading-weight, 700);
    font-size: clamp(2.25rem, 5vw, 4.5rem);
    line-height: 1.1;
    letter-spacing: var(--heading-letter-spacing, -0.01em);
    color: var(--text-primary);
  }
  .rp-atm-subheading {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--text-secondary);
    max-width: 36rem;
    line-height: 1.6;
  }
  .rp-atm-scroll-cta {
    display: inline-block;
    margin-top: 1rem;
    font-family: var(--font-mono, monospace);
    font-size: 0.875rem;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: opacity var(--transition);
  }
  .rp-atm-scroll-cta:hover { opacity: 0.7; }

  /* ── Shared hero copy ──────────────────────────────────────── */
  .rp-overline {
    font-family: var(--font-mono, monospace);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
  }
  .rp-headline {
    font-family: var(--font-heading, sans-serif);
    font-weight: var(--heading-weight, 700);
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.15;
    letter-spacing: var(--heading-letter-spacing, -0.02em);
    color: var(--text-primary);
    margin-bottom: 1.75rem;
  }
  .rp-specialties {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .rp-tag {
    font-family: var(--font-mono, monospace);
    font-size: 0.8rem;
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: var(--border-radius, 6px);
    color: var(--text-secondary);
  }
  .rp-description {
    font-size: 1.125rem;
    line-height: var(--body-line-height, 1.75);
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }
  .rp-cta-btn {
    display: inline-block;
    padding: 0.875rem 2rem;
    background-color: var(--accent);
    color: var(--button-text-color, #fff);
    font-weight: 600;
    border-radius: var(--border-radius, 6px);
    text-decoration: none;
    transition: opacity var(--transition);
    margin-bottom: 1rem;
  }
  .rp-cta-btn:hover { opacity: 0.88; }
  .rp-availability {
    font-size: 0.875rem;
    font-family: var(--font-mono, monospace);
    color: var(--text-secondary);
    margin-top: 0.5rem;
  }

  /* ── Artist statement ──────────────────────────────────────── */
  .rp-statement {
    padding: 6rem 0;
  }
  .rp-statement-body {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .rp-statement-para {
    font-size: 1.125rem;
    line-height: 1.85;
    color: var(--text-secondary);
  }

  /* ── Sections ──────────────────────────────────────────────── */
  .rp-section {
    padding: var(--spacing-section, 5rem) 0;
  }
  .rp-section--alt {
    background-color: var(--bg-secondary);
  }
  .rp-section-heading {
    font-family: var(--font-heading, sans-serif);
    font-weight: var(--heading-weight, 700);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    color: var(--text-primary);
    margin-bottom: 3rem;
    letter-spacing: var(--heading-letter-spacing, -0.01em);
  }

  /* ── Skills ────────────────────────────────────────────────── */
  .rp-skills-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) { .rp-skills-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .rp-skills-grid { grid-template-columns: repeat(3, 1fr); } }
  .rp-skill-card {
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--border-radius, 8px);
    background-color: var(--bg-primary);
  }
  .rp-skill-heading {
    font-size: 0.875rem;
    font-family: var(--font-mono, monospace);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    margin-bottom: 1rem;
  }
  .rp-skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .rp-skill-tag {
    font-size: 0.875rem;
    padding: 0.3rem 0.7rem;
    background-color: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 99px;
    color: var(--text-secondary);
  }
  .rp-skill-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .rp-skill-item {
    font-size: 0.975rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }
  .rp-skill-item::before {
    content: '—';
    margin-right: 0.5em;
    color: var(--border);
  }

  /* ── Process / bio ─────────────────────────────────────────── */
  .rp-process-body {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .rp-process-para {
    font-size: 1rem;
    line-height: var(--body-line-height, 1.75);
    color: var(--text-secondary);
  }
</style>
