---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/ui/Card.astro';
import Badge from '../../components/ui/Badge.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Blog — Fachada" description="Articles about web development, software engineering, and technology">
  <main class="px-4 py-20">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-5xl font-bold mb-4 text-center">Blog</h1>
      <p class="text-xl text-gray-600 dark:text-gray-300 mb-12 text-center">
        Thoughts on web development, software engineering, and technology.
      </p>
      {posts.length === 0 ? (
        <p class="text-center text-gray-600 dark:text-gray-400">
          No blog posts yet. Check back soon!
        </p>
      ) : (
        <div class="space-y-6">
          {posts.map((post) => {
            const formattedDate = new Intl.DateTimeFormat('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            }).format(post.data.date);

            return (
              <Card>
                <article>
                  <a href={`/blog/${post.id.replace('.md', '')}`} class="block group">
                    <h2 class="text-2xl font-bold mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                      {post.data.title}
                    </h2>
                    <time class="text-sm text-gray-500 dark:text-gray-400 mb-3 block">
                      {formattedDate}
                    </time>
                    <p class="text-gray-600 dark:text-gray-300 mb-4">
                      {post.data.description}
                    </p>
                    <div class="flex flex-wrap gap-2">
                      {post.data.tags.map((tag) => (
                        <Badge>{tag}</Badge>
                      ))}
                    </div>
                  </a>
                </article>
              </Card>
            );
          })}
        </div>
      )}
    </div>
  </main>
  <Footer />
</BaseLayout>
