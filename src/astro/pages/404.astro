---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Page Not Found — Fachada" description="This page could not be found" noindex={true}>
  <main class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center">
      <h1 class="text-9xl font-bold text-gray-200 dark:text-gray-800 mb-4">404</h1>
      <h2 class="text-4xl font-bold mb-4">Page Not Found</h2>
      <p class="text-xl text-gray-600 dark:text-gray-300 mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <Button href="/" variant="primary" size="lg">
        Go Home
      </Button>
    </div>
  </main>
  <Footer />
</BaseLayout>
