---
/**
 * Page header with config-driven navigation.
 *
 * Features:
 * - Logo/name on left (from appConfig.seo.name)
 * - Nav items derived from top-level siteTree landing subsections
 * - Contact CTA on right
 * - Mobile hamburger menu (configurable via NavbarConfig)
 * - Theme-aware styling
 *
 * Configuration:
 * - navbar config loaded from appConfig.navbar (NavbarConfig interface)
 * - Defaults to horizontal layout, sticky position, md mobile breakpoint
 * - Fully backward compatible: apps without navbar config still work
 */
import { getActiveAppConfig } from "@fachada/core";
import { getBaseUrl } from "@fachada/core";
import {
  getNavbarConfig,
  getNavbarClasses,
  getMobileMenuAttrs,
} from "../../navbar/navbar.utils";
import "../../navbar/navbar.css";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
const appConfig = getActiveAppConfig();
const siteConfig = appConfig.seo;

const heroTransition = appConfig.navbar?.heroTransition;
const hasHeroTransition = heroTransition?.enabled === true;

// Load navbar configuration with defaults
const navbarConfig = getNavbarConfig(appConfig.navbar);
const navbarClasses = getNavbarClasses(navbarConfig);
const menuAttrs = getMobileMenuAttrs(navbarConfig);
const appearance = navbarConfig.appearance;

const alphaValue =
  typeof appearance?.alpha === "number" ? appearance.alpha : 0.01;
const gradientLight = appearance?.gradientOverlay?.light ?? "none";
const gradientDark =
  appearance?.gradientOverlay?.dark ??
  appearance?.gradientOverlay?.light ??
  "none";
const navbarHeight = appearance?.height ?? "5.5rem";
const navbarOffsetTop = appearance?.offsetTop ?? navbarHeight;
const navbarShadow = appearance?.boxShadow ?? "none";
const headerAppearanceStyle = [
  `--navbar-transparent-alpha: ${alphaValue}`,
  `--navbar-gradient-light: ${gradientLight}`,
  `--navbar-gradient-dark: ${gradientDark}`,
  `--navbar-height: ${navbarHeight}`,
  `--navbar-offset-top: ${navbarOffsetTop}`,
  `--navbar-shadow: ${navbarShadow}`,
]
  .filter(Boolean)
  .join("; ");
const globalNavbarVars = `:root { --navbar-height: ${navbarHeight}; --navbar-offset-top: ${navbarOffsetTop}; }`;

const brandStyle = [
  appearance?.brandTextColor
    ? `color: ${appearance.brandTextColor}`
    : undefined,
  "white-space: nowrap",
  "overflow: visible",
  "text-overflow: clip",
]
  .filter(Boolean)
  .join("; ");

const subsections = appConfig.siteTree?.landing.subsections ?? [];
const navItems = subsections
  .filter((s) => !s.meta.path.substring(1).includes("/"))
  .map((s) => ({
    href: getBaseUrl(s.meta.path),
    label: s.id
      .split("-")
      .map((w: string) => w.charAt(0).toUpperCase() + w.slice(1))
      .join(" "),
    active:
      currentPath === s.meta.path || currentPath.startsWith(s.meta.path + "/"),
  }));

const anchorItems = (navbarConfig.anchorLinks ?? []).map((link) => ({
  href: link.href,
  label: link.label,
}));

const isLanding = currentPath === "/";
---

<style is:global set:html={globalNavbarVars}></style>

<header
  class="navbar backdrop-blur"
  style={headerAppearanceStyle}
  class:list={[
    navbarClasses,
    {
      "navbar-transparent-bg": appearance?.transparent === true,
      "navbar-no-border": appearance?.removeBorder === true,
      "navbar-has-gradient": Boolean(appearance?.gradientOverlay?.light),
      "navbar-has-shadow": Boolean(appearance?.boxShadow),
    },
  ]}
>
  <div class="navbar-inner">
    <!-- Left: Logo / Name -->
    <a
      href={getBaseUrl("/")}
      class="navbar-brand font-pinyon-script"
      style={brandStyle}
      data-shared-navbar-brand={hasHeroTransition ? "" : undefined}
    >
      {siteConfig.name}
    </a>

    <!-- Center: Desktop Navigation (hidden on mobile, shown via .navbar-desktop-nav CSS) -->
    <nav
      class="navbar-desktop-nav"
      style={appearance?.centerDesktopNav
        ? "flex: 1; justify-content: center;"
        : undefined}
    >
      {
        !isLanding && (
          <a
            href={getBaseUrl("/")}
            class="transition-colors"
            style="color: var(--text-secondary);"
          >
            {navbarConfig.backLabel ?? "← Home"}
          </a>
        )
      }
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="transition-colors"
            style={{
              color: item.active ? "var(--accent)" : "var(--text-secondary)",
            }}
          >
            {item.label}
          </a>
        ))
      }
      {
        anchorItems.map((item) => (
          <a
            href={item.href}
            class="transition-colors"
            style="color: var(--text-secondary);"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- Mobile Menu Trigger (hamburger button) -->
    {
      navbarConfig.hasMenu && (
        <button
          class="navbar-hamburger-toggle md:hidden"
          aria-label={menuAttrs["aria-label"] as string}
          aria-expanded={
            menuAttrs["aria-expanded"] === "false" ? "false" : "true"
          }
          data-hamburger-trigger="true"
          onclick="this.parentElement.nextElementSibling.classList.toggle('active')"
        >
          <span />
          <span />
          <span />
        </button>
      )
    }

    <!-- Right: Contact CTA -->
    {
      (siteConfig.social.whatsapp || siteConfig.social.email) && (
        <a
          href={
            siteConfig.social.whatsapp
              ? siteConfig.social.whatsappMessage
                ? `${siteConfig.social.whatsapp}?text=${encodeURIComponent(siteConfig.social.whatsappMessage)}`
                : siteConfig.social.whatsapp
              : `mailto:${siteConfig.social.email}`
          }
          class="navbar-cta navbar-cta-desktop"
          target={siteConfig.social.whatsapp ? "_blank" : undefined}
          rel={siteConfig.social.whatsapp ? "noopener noreferrer" : undefined}
        >
          {siteConfig.social.whatsapp ? "WhatsApp" : "Contacto"}
        </a>
      )
    }
  </div>

  <!-- Mobile Navigation Menu (hidden by default, shown on button click) -->
  {
    navbarConfig.hasMenu && (
      <nav class="navbar-mobile-menu md:hidden">
        {!isLanding && (
          <a
            href={getBaseUrl("/")}
            class="transition-colors"
            style="color: var(--text-secondary);"
            onclick="this.closest('.navbar-mobile-menu').classList.remove('active')"
          >
            {navbarConfig.backLabel ?? "← Home"}
          </a>
        )}
        {navItems.map((item) => (
          <a
            href={item.href}
            class="transition-colors"
            style={{
              color: item.active ? "var(--accent)" : "var(--text-secondary)",
            }}
            onclick="this.closest('.navbar-mobile-menu').classList.remove('active')"
          >
            {item.label}
          </a>
        ))}
        {anchorItems.map((item) => (
          <a
            href={item.href}
            class="transition-colors"
            style="color: var(--text-secondary);"
            onclick="this.closest('.navbar-mobile-menu').classList.remove('active')"
          >
            {item.label}
          </a>
        ))}
        {(siteConfig.social.whatsapp || siteConfig.social.email) && (
          <a
            href={
              siteConfig.social.whatsapp
                ? siteConfig.social.whatsappMessage
                  ? `${siteConfig.social.whatsapp}?text=${encodeURIComponent(siteConfig.social.whatsappMessage)}`
                  : siteConfig.social.whatsapp
                : `mailto:${siteConfig.social.email}`
            }
            class="navbar-cta mt-2"
            target={siteConfig.social.whatsapp ? "_blank" : undefined}
            rel={siteConfig.social.whatsapp ? "noopener noreferrer" : undefined}
            onclick="this.closest('.navbar-mobile-menu').classList.remove('active')"
          >
            {siteConfig.social.whatsapp ? "WhatsApp" : "Contacto"}
          </a>
        )}
      </nav>
    )
  }
</header>

<style>
  header.navbar {
    box-sizing: border-box;
    height: var(--navbar-height, 5.5rem);
    min-height: var(--navbar-height, 5.5rem);
    padding: 0;
  }

  header.navbar .navbar-inner {
    box-sizing: border-box;
    height: 100%;
    padding-top: 0;
    padding-bottom: 0;
    align-items: center;
  }

  header.navbar.navbar-transparent-bg {
    background-color: rgba(255, 255, 255, var(--navbar-transparent-alpha));
  }

  header.navbar.navbar-no-border {
    border-bottom: none !important;
  }

  header.navbar.navbar-has-shadow {
    box-shadow: var(--navbar-shadow);
  }

  header.navbar.navbar-has-gradient {
    background-image: var(--navbar-gradient-light);
  }

  @media (prefers-color-scheme: dark) {
    header.navbar.navbar-has-gradient {
      background-image: var(--navbar-gradient-dark);
    }
  }

  @media (max-width: 767px) {
    header.navbar {
      position: relative;
      backdrop-filter: blur(4px);
    }
  }
</style>
