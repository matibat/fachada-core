---
import Card from '../ui/Card.astro';
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';

export interface Props {
  title: string;
  description: string;
  stack: string[];
  coverImage: string;
  liveUrl?: string;
  githubUrl?: string;
  slug: string;
  roles?: string[];
}

const { title, description, stack, coverImage, liveUrl, githubUrl, slug, roles } = Astro.props;
---

<Card>
  <div class="space-y-4">
    <img
      src={coverImage}
      alt={title}
      class="w-full h-48 object-cover rounded-lg"
      loading="lazy"
    />
    <div class="flex items-start justify-between gap-2">
      <h3 class="text-2xl font-bold">{title}</h3>
      {roles && roles.length > 0 && (
        <span
          class="text-xs font-mono uppercase tracking-widest px-2 py-1 rounded-full shrink-0 mt-1"
          style="background-color: var(--bg-tertiary, var(--bg-primary)); border: 1px solid var(--border); color: var(--text-secondary);"
        >
          {roles[0]}
        </span>
      )}
    </div>
    <p style="color: var(--text-secondary);">{description}</p>
    <div class="flex flex-wrap gap-2">
      {stack.map((tech) => (
        <Badge variant="primary">{tech}</Badge>
      ))}
    </div>
    <div class="flex flex-wrap gap-3 pt-2">
      <Button href={`/projects/${slug.replace('.md', '')}`} variant="primary" size="sm">
        View Case Study
      </Button>
      {liveUrl && (
        <Button href={liveUrl} variant="outline" size="sm">
          Live Demo
        </Button>
      )}
      {githubUrl && (
        <Button href={githubUrl} variant="outline" size="sm">
          GitHub
        </Button>
      )}
    </div>
  </div>
</Card>
