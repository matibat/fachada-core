---
import { siteConfig } from '../../config';
import Button from '../ui/Button.astro';

const primaryRole = siteConfig.roles.find(r => r.id === siteConfig.primaryRole) ?? siteConfig.roles[0];
const isMultiRole = siteConfig.roles.length > 1;
---

<section class="min-h-screen flex items-center justify-center px-4 py-20" data-testid="hero-section">
  <div class="max-w-4xl mx-auto text-center">
    <!-- Overline label — uses mono font via CSS var -->
    <p
      class="hero-overline text-sm uppercase tracking-widest mb-6"
      style="color: var(--text-secondary); font-family: var(--font-mono);"
    >
      {isMultiRole
        ? siteConfig.roles.filter(r => r.featured).map(r => r.title).join(' & ')
        : primaryRole.title}
    </p>

    <h1
      class="font-bold mb-6"
      data-testid="hero-title"
    >
      {siteConfig.name}
    </h1>

    <p class="text-xl md:text-2xl mb-8 max-w-2xl mx-auto" data-testid="hero-description" style="color: var(--text-secondary);">
      {siteConfig.description}
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button href="#projects" variant="primary" size="lg" class="hero-primary-cta">
        View Work
      </Button>
      <Button href="#contact" variant="outline" size="lg">
        Get in Touch
      </Button>
    </div>
  </div>
</section>

<style>
  :global(.hero-primary-cta) {
    box-shadow: 0 8px 18px var(--shadow);
  }
</style>
