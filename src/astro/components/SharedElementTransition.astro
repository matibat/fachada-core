---
/**
 * SharedElementTransition — orchestrates the scroll-linked hero-to-navbar brand
 * transition.
 *
 * Responsibilities:
 *   1. Injects the scroll-transition CSS stylesheet.
 *   2. Publishes --st-start, --st-end, --st-easing CSS custom properties to :root
 *      so the stylesheet can read app configuration without runtime JS.
 *   3. Detects CSS scroll-driven animation support and marks <html> accordingly.
 *   4. Provides a requestAnimationFrame-based fallback for unsupported browsers.
 *
 * This component renders nothing visible — it is a pure infrastructure concern.
 * It is included by BaseLayout.astro only when appConfig.navbar.heroTransition
 * is enabled.
 */
import type { HeroNavbarTransitionConfig } from "../../types/scroll-transition.types";
import "../../scroll-transition/shared-element-transition.css";

interface Props {
  config: HeroNavbarTransitionConfig;
}

const { config } = Astro.props;

const startScroll = config.startScroll ?? 0;
const endScroll = config.endScroll ?? 300;
const easing = config.easing ?? "ease";

// Transition duration used by the JS fallback (not the CSS scroll-driven path).
const FALLBACK_TRANSITION_MS = 150;

// Sanitize easing: only allow valid CSS easing keywords and cubic-bezier().
// This value is injected via set:html into a <style> block; restrict to known-safe
// CSS easing syntax to prevent CSS injection from a manipulated config file.
const EASING_ALLOWLIST =
  /^(linear|ease|ease-in|ease-out|ease-in-out|step-start|step-end|cubic-bezier\([\d.,\s-]+\))$/;
const safeEasing = EASING_ALLOWLIST.test(easing) ? easing : "ease";
---

<!--
  Inject CSS custom properties that parameterise the scroll animation range and
  easing. Written to :root so the stylesheet can consume them without JS.
  Using a script (not a style tag) because Astro processes <style> blocks
  at build time; script is:inline runs before the first paint.
-->
<script
  is:inline
  define:vars={{
    startScroll,
    endScroll,
    safeEasing,
    FALLBACK_TRANSITION_MS,
  }}
>
  (function () {
    var root = document.documentElement;
    root.style.setProperty("--st-start", startScroll + "px");
    root.style.setProperty("--st-end", endScroll + "px");
    root.style.setProperty("--st-easing", safeEasing);
    root.style.setProperty(
      "--st-transition-duration",
      FALLBACK_TRANSITION_MS + "ms",
    );
  })();
</script>

<script
  is:inline
  define:vars={{
    startScroll,
    endScroll,
  }}
>
  (function () {
    // Feature-detect CSS scroll-driven animations.
    // CSS.supports is available on all modern browsers; older ones fall through.
    var supportsScrollTimeline =
      typeof CSS !== "undefined" &&
      CSS.supports("animation-timeline", "scroll()");

    if (supportsScrollTimeline) {
      // Mark the document so CSS fallback rules are suppressed.
      document.documentElement.classList.add("has-scroll-timeline");
      // The CSS scroll-driven animation handles everything — no JS needed per frame.
      return;
    }

    // ── JS fallback path ───────────────────────────────────────────────────────
    // Applies opacity + transform via class toggling on a rAF-throttled scroll
    // listener. No inline style mutations per frame — class additions only.

    var heroBrand = document.querySelector("[data-shared-hero-brand]");
    var navbarBrand = document.querySelector("[data-shared-navbar-brand]");

    if (!heroBrand || !navbarBrand) return;

    // Respect reduced motion at the JS level too (belt-and-suspenders with CSS).
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      navbarBrand.classList.add("shared-brand-visible");
      return;
    }

    var rafPending = false;

    function update() {
      rafPending = false;
      var scrollY = window.scrollY;
      var range = endScroll - startScroll;
      var progress =
        range <= 0
          ? 1
          : Math.min(1, Math.max(0, (scrollY - startScroll) / range));

      if (progress >= 0.5) {
        navbarBrand.classList.add("shared-brand-visible");
        heroBrand.classList.add("shared-brand-hidden");
      } else {
        navbarBrand.classList.remove("shared-brand-visible");
        heroBrand.classList.remove("shared-brand-hidden");
      }
    }

    function onScroll() {
      if (!rafPending) {
        rafPending = true;
        requestAnimationFrame(update);
      }
    }

    window.addEventListener("scroll", onScroll, { passive: true });

    // Run once on load in case the page is already scrolled.
    update();
  })();
</script>
