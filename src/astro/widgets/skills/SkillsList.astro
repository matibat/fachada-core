---
import { siteConfig } from "../../config";
import { profileConfig } from "../../profile.config";
import Badge from "../../components/ui/Badge.astro";

const { skills: skillCategories } = profileConfig;
const isFramework = siteConfig.roles.some((r) => r.id === "framework");
const heading = isFramework
  ? "Features & Architecture"
  : "Skills & Technologies";
---

<section
  id="skills"
  class="section-wrapper"
  data-testid="skills-section"
  style="background-color: var(--bg-secondary);"
>
  <div class="section-inner-md">
    <h2 class="text-4xl font-bold mb-12 text-center" data-index="02">
      {heading}
    </h2>
    <div class="skills-list">
      {
        skillCategories.map((category) => (
          <div class="skills-list-row">
            <h3 class="skills-list-category text-lg font-semibold">
              {category.name}
            </h3>
            <div class="flex-wrap gap-2">
              {category.skills.map((skill) => (
                <Badge>{skill}</Badge>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .skills-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-element);
  }

  .skills-list-row {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-bottom: var(--spacing-element);
    border-bottom: 1px solid var(--border);
  }

  .skills-list-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  @media (min-width: 640px) {
    .skills-list-row {
      flex-direction: row;
      align-items: flex-start;
    }

    .skills-list-category {
      flex-shrink: 0;
      width: 11rem;
      padding-top: 0.25rem;
    }
  }
</style>
