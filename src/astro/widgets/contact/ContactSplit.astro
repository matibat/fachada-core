---
import { siteConfig } from "../../config";
import { profileConfig } from "../../profile.config";
import Card from "../../components/ui/Card.astro";
import Button from "../../components/ui/Button.astro";
import { resolveContactMessage } from "@fachada/core";

export interface Props {
  message?: string;
}

const { message: messageProp } = Astro.props;
const contactMessage = resolveContactMessage(
  messageProp,
  profileConfig.contactMessage,
);

const { social } = siteConfig;

// Primary CTA: prefer WhatsApp, then email
const primaryHref =
  social.whatsapp ?? (social.email ? `mailto:${social.email}` : undefined);
const primaryLabel = social.whatsapp ? "WhatsApp" : "Send Email";

// Secondary social links (all optional)
const socialLinks = [
  social.instagram && { href: social.instagram, label: "Instagram" },
  social.github && { href: social.github, label: "GitHub" },
  social.linkedin && { href: social.linkedin, label: "LinkedIn" },
  social.twitter && { href: social.twitter, label: "Twitter" },
  social.whatsapp &&
    social.email && { href: `mailto:${social.email}`, label: "Email" },
].filter(Boolean) as { href: string; label: string }[];
---

<section
  id="contact"
  class="section-wrapper"
  data-testid="contact-section"
  style="background-color: var(--bg-secondary);"
>
  <div class="section-inner-lg">
    <div class="contact-split-grid">
      <!-- Left: heading + message + social links -->
      <div class="contact-split-info">
        <h2 class="text-4xl font-bold mb-6" data-index="04">Contacto</h2>
        <p class="text-lg mb-8" style="color: var(--text-secondary);">
          {contactMessage}
        </p>
        {
          socialLinks.length > 0 && (
            <div class="contact-split-socials">
              {socialLinks.map((link) => (
                <a
                  href={link.href}
                  class="contact-social-link"
                  aria-label={link.label}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {link.label}
                </a>
              ))}
            </div>
          )
        }
      </div>

      <!-- Right: CTA card -->
      {
        primaryHref && (
          <div class="contact-split-cta">
            <Card>
              <div class="flex-row-start gap-4">
                <p
                  class="text-sm uppercase tracking-widest"
                  style="color: var(--text-secondary); font-family: var(--font-mono);"
                >
                  Ready to connect?
                </p>
                <Button
                  href={primaryHref}
                  variant="primary"
                  size="lg"
                  class="contact-email-button w-full justify-center"
                  target={social.whatsapp ? "_blank" : undefined}
                  rel={social.whatsapp ? "noopener noreferrer" : undefined}
                >
                  {primaryLabel}
                </Button>
              </div>
            </Card>
          </div>
        )
      }
    </div>
  </div>
</section>

<style>
  .contact-split-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .contact-split-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }
  }

  .contact-split-socials {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .contact-social-link {
    color: var(--text-secondary);
    transition: color var(--transition);
    text-decoration: none;
  }

  .contact-social-link:hover {
    color: var(--accent);
  }
</style>

