---
import { siteConfig } from "../../config";
import { profileConfig } from "../../profile.config";
import Card from "../../components/ui/Card.astro";
import Button from "../../components/ui/Button.astro";
import { resolveContactMessage } from "@fachada/core";

export interface Props {
  message?: string;
  /** Section heading. Defaults to a language-aware label when not provided. */
  heading?: string;
}

const isSpanish = siteConfig.lang === "es";
const { message: messageProp, heading = isSpanish ? "Contacto" : "Contact" } =
  Astro.props;
const contactMessage = resolveContactMessage(
  messageProp,
  profileConfig.contactMessage,
);

const { social } = siteConfig;
const primaryHref = social.whatsapp;
const secondaryHref = social.instagram;
---

<section id="contact" class="section-wrapper" data-testid="contact-section">
  <div class="section-inner-lg">
    <div class="contact-split-grid">
      <!-- Left: heading + message + social links -->
      <div class="contact-split-info">
        <h2 class="text-4xl font-bold mb-6" data-index="04">{heading}</h2>
        <p class="text-lg mb-8" style="color: var(--text-secondary);">
          {contactMessage}
        </p>
        {
          secondaryHref && (
            <div class="contact-split-socials">
              <a
                href={secondaryHref}
                class="contact-social-link"
                aria-label="Instagram"
                target="_blank"
                rel="noopener noreferrer"
              >
                Instagram
              </a>
            </div>
          )
        }
      </div>

      <!-- Right: CTA card -->
      {
        primaryHref && (
          <div class="contact-split-cta">
            <Card>
              <div class="flex-row-start gap-4">
                <p
                  class="text-sm uppercase tracking-widest"
                  style="color: var(--text-secondary); font-family: var(--font-mono);"
                >
                  {isSpanish
                    ? "Escribime por WhatsApp"
                    : "Reach out on WhatsApp"}
                </p>
                <Button
                  href={primaryHref}
                  variant="primary"
                  size="lg"
                  class="contact-email-button w-full justify-center"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  WhatsApp
                </Button>
              </div>
            </Card>
          </div>
        )
      }
    </div>
  </div>
</section>

<style>
  .contact-split-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .contact-split-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }
  }

  .contact-split-socials {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .contact-social-link {
    color: var(--text-secondary);
    transition: color var(--transition);
    text-decoration: none;
  }

  .contact-social-link:hover {
    color: var(--accent);
  }
</style>
