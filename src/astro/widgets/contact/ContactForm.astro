---
// ContactForm — generic contact form with optional WhatsApp fallback note.
// All visible strings and configuration are driven by props.

export interface Props {
  namePlaceholder?: string;
  emailPlaceholder?: string;
  messagePlaceholder?: string;
  submitLabel?: string;
  whatsappNote?: string;
  whatsappHref?: string;
  serviceOptions?: { value: string; label: string }[];
  servicePlaceholder?: string;
  formAction?: string;
}

const {
  namePlaceholder = "Name",
  emailPlaceholder = "email@example.com",
  messagePlaceholder = "Your message...",
  submitLabel = "Send",
  whatsappNote,
  whatsappHref,
  serviceOptions,
  servicePlaceholder = "Select a service",
  formAction = "#",
} = Astro.props;

const hasServiceOptions =
  Array.isArray(serviceOptions) && serviceOptions.length > 0;
const showWhatsapp = Boolean(whatsappNote && whatsappHref);
---

<form class="contact-form" method="GET" action={formAction}>
  <div class="form-group">
    <input
      type="text"
      name="name"
      placeholder={namePlaceholder}
      required
      class="form-input"
    />
  </div>
  <div class="form-group">
    <input
      type="email"
      name="email"
      placeholder={emailPlaceholder}
      required
      class="form-input"
    />
  </div>
  {
    hasServiceOptions && (
      <div class="form-group">
        <select name="service" class="form-select">
          <option value="">{servicePlaceholder}</option>
          {serviceOptions!.map((opt) => (
            <option value={opt.value}>{opt.label}</option>
          ))}
        </select>
      </div>
    )
  }
  <div class="form-group">
    <textarea
      name="message"
      rows="5"
      placeholder={messagePlaceholder}
      class="form-textarea"></textarea>
  </div>
  <button type="submit" class="form-submit">{submitLabel}</button>
</form>
{
  showWhatsapp && (
    <p class="contact-whatsapp-note">
      {whatsappNote} <a href={whatsappHref}>WhatsApp</a>.
    </p>
  )
}

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 480px;
    width: 100%;
  }

  .form-group {
    display: flex;
    flex-direction: column;
  }

  .form-input,
  .form-select,
  .form-textarea {
    padding: 0.75rem 1rem;
    border: 1px solid var(--border, #ccc);
    border-radius: 0.375rem;
    background: var(--bg-primary);
    color: var(--text-primary);
    font-size: 1rem;
    font-family: inherit;
    width: 100%;
    box-sizing: border-box;
    transition: border-color 0.2s ease;
  }

  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    outline: none;
    border-color: var(--accent);
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-submit {
    padding: 0.75rem 2rem;
    background: var(--accent);
    color: var(--bg-primary);
    border: none;
    border-radius: 0.375rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    align-self: flex-start;
    transition: opacity 0.2s ease;
  }

  .form-submit:hover {
    opacity: 0.85;
  }

  .contact-whatsapp-note {
    margin-top: 1rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .contact-whatsapp-note a {
    color: var(--accent);
    text-decoration: underline;
  }
</style>
