---
import { siteConfig } from "../../config";
import { profileConfig } from "../../profile.config";
import Card from "../../components/ui/Card.astro";
import Button from "../../components/ui/Button.astro";
import { resolveContactMessage } from "@fachada/core";

export interface Props {
  message?: string;
  /** Section heading. Defaults to a language-aware label when not provided. */
  heading?: string;
}

const isSpanish = siteConfig.lang === "es";
const { message: messageProp, heading = isSpanish ? "Contacto" : "Contact" } =
  Astro.props;
const contactMessage = resolveContactMessage(
  messageProp,
  profileConfig.contactMessage,
);

const { social } = siteConfig;
const primaryHref = social.whatsapp;
const secondaryHref = social.instagram;
---

<section id="contact" class="section-wrapper" data-testid="contact-section">
  <div class="section-inner-md">
    <h2 class="text-4xl font-bold mb-8 text-center" data-index="04">
      {heading}
    </h2>
    <Card>
      <div class="text-center space-y-6">
        <p class="text-lg" style="color: var(--text-secondary);">
          {contactMessage}
        </p>
        {
          (primaryHref || secondaryHref) && (
            <div class="contact-cta-row">
              {primaryHref && (
                <Button
                  href={primaryHref}
                  variant="primary"
                  size="lg"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  WhatsApp
                </Button>
              )}
              {secondaryHref && (
                <Button
                  href={secondaryHref}
                  variant="outline"
                  size="lg"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Instagram
                </Button>
              )}
            </div>
          )
        }
      </div>
    </Card>
  </div>
</section>

<style>
  #contact.section-wrapper {
    min-height: 100dvh;
    display: flex;
    align-items: center;
  }

  #contact .section-inner-md {
    width: 100%;
  }

  .contact-social-link:hover {
    color: var(--accent) !important;
  }

  .contact-cta-row {
    display: flex;
    flex-direction: row;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }
</style>
