---
import type { GalleryImage } from "@fachada/core";
import { appConfig } from "virtual:fachada/active-app";

export interface Props {
  title?: string;
  intro?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const { title, intro, ctaLabel, ctaHref } = Astro.props;

const images: GalleryImage[] = appConfig.gallery?.images ?? [];

const steps = [
  {
    icon: "📅",
    title: "Agendá",
    description: "Elegí la fecha que mejor te queda y reservamos tu lugar.",
  },
  {
    icon: "✏️",
    title: "Diseñamos",
    description: "Trabajamos juntos en el concepto hasta que sea tuyo.",
  },
  {
    icon: "🪡",
    title: "Te tatuás",
    description: "Nos vemos en el estudio y lo hacemos realidad.",
  },
];
---

<section id="tatuajes" class="tatuajes-section section-wrapper">
  <div class="section-inner-md">
    <h2 class="tatuajes-heading">{title || "Tatuajes"}</h2>
    {intro && <p class="tatuajes-intro">{intro}</p>}

    <!-- Process steps -->
    <ol class="tatuajes-steps">
      {
        steps.map((step) => (
          <li class="tatuajes-step">
            <div class="tatuajes-step-icon" aria-hidden="true">
              {step.icon}
            </div>
            <h3 class="tatuajes-step-title">{step.title}</h3>
            <p class="tatuajes-step-desc">{step.description}</p>
          </li>
        ))
      }
    </ol>

    <!-- Gallery -->
    <div class="tatuajes-gallery">
      {
        images.map((image) => (
          <div class="tatuajes-gallery-item">
            <img src={image.src} alt={image.alt} loading="lazy" />
            {image.caption && <p class="tatuajes-caption">{image.caption}</p>}
          </div>
        ))
      }
    </div>

    {
      ctaLabel && ctaHref && (
        <div class="tatuajes-cta-wrap">
          <a href={ctaHref} class="tatuajes-cta">
            {ctaLabel}
          </a>
        </div>
      )
    }
  </div>
</section>

<style>
  .tatuajes-section {
    padding: 4rem 1rem;
    min-height: 100dvh;
    display: flex;
    align-items: center;
  }

  .tatuajes-heading {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--text-primary);
    text-align: center;
  }

  .tatuajes-intro {
    font-size: 1.125rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    max-width: 60ch;
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  /* Process steps */
  .tatuajes-steps {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    list-style: none;
    padding: 0;
    margin: 0 0 3rem;
    text-align: center;
  }

  @media (min-width: 640px) {
    .tatuajes-steps {
      flex-direction: row;
      align-items: flex-start;
      gap: 1.5rem;
    }
  }

  .tatuajes-step {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    position: relative;
  }

  @media (min-width: 640px) {
    .tatuajes-step:not(:last-child)::after {
      content: "";
      position: absolute;
      top: 2rem;
      right: calc(-0.75rem);
      width: 1.5rem;
      height: 2px;
      background: var(--accent);
      opacity: 0.4;
    }
  }

  .tatuajes-step-icon {
    border-radius: 50%;
    background-color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .tatuajes-step-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .tatuajes-step-desc {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
    max-width: 20ch;
  }

  /* Gallery */
  .tatuajes-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
    margin: 2rem 0;
    text-align: left;
  }

  .tatuajes-gallery-item {
    overflow: hidden;
    border-radius: 0.5rem;
  }

  .tatuajes-gallery-item img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .tatuajes-gallery-item img:hover {
    transform: scale(1.03);
  }

  .tatuajes-caption {
    font-size: 0.875rem;
    color: var(--text-secondary);
    padding: 0.5rem;
    margin: 0;
  }

  .tatuajes-cta-wrap {
    text-align: center;
  }

  .tatuajes-cta {
    display: inline-block;
    margin-top: 2rem;
    padding: 0.75rem 2rem;
    background: var(--accent);
    color: var(--bg-primary);
    border-radius: 0.25rem;
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.2s ease;
  }

  .tatuajes-cta:hover {
    opacity: 0.85;
  }
</style>
