---
import type { GalleryImage } from "@fachada/core";
import { appConfig } from "virtual:fachada/active-app";

export interface Props {
  title?: string;
  intro?: string;
  ctaLabel?: string;
  ctaHref?: string;
  sectionId?: string;
  images?: GalleryImage[];
}

const {
  title,
  intro,
  ctaLabel,
  ctaHref,
  sectionId = "image-section",
  images: imagesProp,
} = Astro.props;

const images: GalleryImage[] = imagesProp ?? appConfig.gallery?.images ?? [];
---

<section id={sectionId} class="image-section section-wrapper">
  {title && <h2>{title}</h2>}
  {intro && <p class="image-section-intro">{intro}</p>}
  <div class="image-section-gallery">
    {
      images.map((image) => (
        <div class="image-section-gallery-item">
          <img src={image.src} alt={image.alt} loading="lazy" />
          {image.caption && <p class="image-section-caption">{image.caption}</p>}
        </div>
      ))
    }
  </div>
  {
    ctaLabel && ctaHref && (
      <a href={ctaHref} class="image-section-cta">
        {ctaLabel}
      </a>
    )
  }
</section>

<style>
  .image-section {
    padding: 4rem 1rem;
  }

  .image-section h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .image-section-intro {
    font-size: 1.125rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    max-width: 60ch;
  }

  .image-section-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
    margin: 2rem 0;
  }

  .image-section-gallery-item {
    overflow: hidden;
    border-radius: 0.5rem;
  }

  .image-section-gallery-item img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .image-section-gallery-item img:hover {
    transform: scale(1.03);
  }

  .image-section-caption {
    font-size: 0.875rem;
    color: var(--text-secondary);
    padding: 0.5rem;
    margin: 0;
  }

  .image-section-cta {
    display: inline-block;
    margin-top: 2rem;
    padding: 0.75rem 2rem;
    background: var(--accent);
    color: var(--bg-primary);
    border-radius: 0.25rem;
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.2s ease;
  }

  .image-section-cta:hover {
    opacity: 0.85;
  }
</style>
