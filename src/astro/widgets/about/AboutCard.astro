---
import Card from "../../components/ui/Card.astro";

export interface Props {
  paragraphs?: string[];
  heading?: string;
}

const { paragraphs = [], heading = "About Me" } = Astro.props;
---

<section id="about" class="section-wrapper about-section">
  <div class="section-inner-md">
    <h2 class="text-4xl font-bold mb-8 text-center" data-index="01">
      {heading}
    </h2>
    <Card>
      <div class="max-w-none">
        {
          paragraphs.map((paragraph) => (
            <p
              class="text-lg mb-4 last:mb-0"
              style="color: var(--text-secondary);"
            >
              {paragraph}
            </p>
          ))
        }
      </div>
    </Card>
  </div>
</section>
