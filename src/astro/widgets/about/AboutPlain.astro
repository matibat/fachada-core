---
export interface Props {
  paragraphs?: string[];
  heading?: string;
}

const { paragraphs = [], heading = "About Me" } = Astro.props;
---

<section id="about" class="section-wrapper">
  <div class="section-inner-sm">
    <h2 class="text-4xl font-bold mb-10" data-index="01">{heading}</h2>
    <div class="about-plain-body">
      {
        paragraphs.map((paragraph) => (
          <p
            class="about-plain-paragraph"
            style="color: var(--text-secondary);"
          >
            {paragraph}
          </p>
        ))
      }
    </div>
  </div>
</section>

<style>
  .about-plain-body {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-element);
  }

  .about-plain-paragraph {
    font-size: 1.2rem;
    line-height: var(--body-line-height);
  }
</style>
