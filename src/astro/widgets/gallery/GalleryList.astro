---
import type { GalleryConfig } from "@fachada/core";

export interface Props {
  gallery: GalleryConfig;
}

const { gallery } = Astro.props;
const { title, description, images } = gallery;
---

<section id="gallery" class="gallery-section section-wrapper">
  <div class="section-inner-md">
    {
      title && (
        <h2 class="gallery-title" data-testid="gallery-title">
          {title}
        </h2>
      )
    }
    {description && <p class="gallery-description">{description}</p>}

    <div class="gallery-list" data-testid="gallery-list">
      {
        images.map((img) => (
          <figure class="gallery-list-item">
            <div class="gallery-list-thumb">
              <img
                src={img.src}
                alt={img.alt}
                class="gallery-list-image"
                loading="lazy"
              />
            </div>
            {img.caption && (
              <figcaption class="gallery-list-caption">
                {img.caption}
              </figcaption>
            )}
          </figure>
        ))
      }
    </div>
  </div>
</section>

<style>
  .gallery-section {
    padding: var(--spacing-section) 1.5rem;
  }

  .gallery-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--accent);
  }

  .gallery-description {
    color: var(--text-secondary);
    margin-bottom: 2rem;
    font-size: 1.1rem;
  }

  .gallery-list {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
    scrollbar-width: thin;
    scrollbar-color: var(--accent) var(--bg-secondary);
  }

  .gallery-list-item {
    flex: 0 0 auto;
    margin: 0;
    border-radius: var(--border-radius);
    overflow: hidden;
    box-shadow: 0 4px 12px var(--shadow);
    background: var(--bg-secondary);
    width: 240px;
  }

  .gallery-list-thumb {
    width: 240px;
    height: 180px;
    overflow: hidden;
  }

  .gallery-list-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition);
  }

  .gallery-list-item:hover .gallery-list-image {
    transform: scale(1.04);
  }

  .gallery-list-caption {
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
  }
</style>
