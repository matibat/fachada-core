---
import type { GalleryConfig } from "@fachada/core";
import {
  resolveGalleryDefaults,
  GALLERY_TRANSITION_EASING,
  GALLERY_TRANSITION_STYLES,
} from "../../../gallery/galleryConfig";

export interface Props {
  gallery: GalleryConfig;
}

const { gallery } = Astro.props;
const resolved = resolveGalleryDefaults(gallery);
const {
  title,
  description,
  images,
  autoScrollEnabled,
  autoScrollInterval,
  transition,
  transitionStyle,
  transitionSpeed,
} = resolved;

const transitionClass = GALLERY_TRANSITION_STYLES[transitionStyle];
const transitionEasing = GALLERY_TRANSITION_EASING[transition];
---

<section id="gallery" class="gallery-section section-wrapper">
  <div class="section-inner-md">
    {
      title && (
        <h2 class="gallery-title" data-testid="gallery-title">
          {title}
        </h2>
      )
    }
    {description && <p class="gallery-description">{description}</p>}

    <div
      class={`carousel-root ${transitionClass}`}
      data-auto-scroll={autoScrollEnabled ? "true" : "false"}
      data-scroll-interval={autoScrollInterval ?? 0}
      data-transition-style={transitionStyle}
      data-transition-easing={transitionEasing}
      data-transition-speed={transitionSpeed ?? ""}
      data-testid="gallery-carousel"
    >
      <div class="carousel-track" aria-live="polite">
        {
          images.map((img, idx) => (
            <figure
              class={`carousel-slide ${idx === 0 ? "is-active" : ""}`}
              aria-hidden={idx !== 0 ? "true" : undefined}
              data-index={idx}
            >
              <img
                src={img.src}
                alt={img.alt}
                class="carousel-image"
                loading={idx === 0 ? "eager" : "lazy"}
              />
              {img.caption && (
                <figcaption class="carousel-caption">{img.caption}</figcaption>
              )}
            </figure>
          ))
        }
      </div>

      {
        images.length > 1 && (
          <div class="carousel-controls">
            <button
              class="carousel-btn carousel-btn--prev"
              aria-label="Previous image"
              type="button"
            >
              ←
            </button>
            <div
              class="carousel-dots"
              role="tablist"
              aria-label="Gallery slides"
            >
              {images.map((img, idx) => (
                <button
                  class={`carousel-dot ${idx === 0 ? "is-active" : ""}`}
                  data-index={idx}
                  role="tab"
                  aria-selected={idx === 0 ? "true" : "false"}
                  aria-label={`Slide ${idx + 1}: ${img.alt}`}
                  type="button"
                />
              ))}
            </div>
            <button
              class="carousel-btn carousel-btn--next"
              aria-label="Next image"
              type="button"
            >
              →
            </button>
          </div>
        )
      }
    </div>
  </div>
</section>

<style is:global>
  .gallery-section {
    min-height: 100dvh;
    display: flex;
    align-items: center;
  }

  .gallery-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--accent);
  }

  .gallery-description {
    color: var(--text-secondary);
    margin-bottom: 2rem;
    font-size: 1.1rem;
  }

  .carousel-root {
    position: relative;
  }

  .carousel-track {
    position: relative;
    overflow: hidden;
    border-radius: var(--border-radius);
    aspect-ratio: 4 / 3;
    background: var(--bg-secondary);
  }

  .carousel-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    /* Duration and easing are set via JS from data attributes;
       skin's --transition is the fallback so the gallery always
       inherits the site's motion budget when no explicit speed is given. */
    transition-property: opacity, transform;
    transition-duration: var(--gallery-speed, var(--transition-duration, 0.5s));
    transition-timing-function: var(--gallery-easing, ease);
    will-change: transform, opacity;
    transform: none;
    margin: 0;
    z-index: 0;
  }

  .carousel-slide.is-active {
    opacity: 1;
    z-index: 1;
    position: absolute;
  }

  /* ── Transition style: fade (default) ──────────────────────────── */
  /* No transform change needed — opacity handles everything.        */

  /* ── Transition style: ltr ─────────────────────────────────────── */
  /* Inactive slides rest to the right; active slides in place.      */
  .carousel--ltr .carousel-slide:not(.is-active):not(.is-leaving) {
    transform: translateX(100%);
  }
  .carousel--ltr .carousel-slide.is-leaving {
    transform: translateX(-100%);
  }

  /* ── Transition style: rtl ─────────────────────────────────────── */
  .carousel--rtl .carousel-slide:not(.is-active):not(.is-leaving) {
    transform: translateX(-100%);
  }
  .carousel--rtl .carousel-slide.is-leaving {
    transform: translateX(100%);
  }

  /* ── Transition style: top-to-bottom ───────────────────────────── */
  .carousel--ttb .carousel-slide:not(.is-active):not(.is-leaving) {
    transform: translateY(-100%);
  }
  .carousel--ttb .carousel-slide.is-leaving {
    transform: translateY(100%);
  }

  /* ── Transition style: bottom-to-top ───────────────────────────── */
  .carousel--btt .carousel-slide:not(.is-active):not(.is-leaving) {
    transform: translateY(100%);
  }
  .carousel--btt .carousel-slide.is-leaving {
    transform: translateY(-100%);
  }

  /* ── Transition style: zoom-in ─────────────────────────────────── */
  .carousel--zoom-in .carousel-slide:not(.is-active) {
    transform: scale(0.9);
  }

  /* ── Transition style: zoom-out ────────────────────────────────── */
  .carousel--zoom-out .carousel-slide:not(.is-active) {
    transform: scale(1.1);
  }

  .carousel-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .carousel-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.75rem 1rem;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
    color: #fff;
    font-size: 0.9rem;
  }

  .carousel-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 1rem;
  }

  .carousel-btn {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    color: var(--text-primary);
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1rem;
    transition:
      background var(--transition),
      color var(--transition);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .carousel-btn:hover {
    background: var(--accent);
    color: var(--button-text-color, #fff);
    border-color: var(--accent);
  }

  .carousel-dots {
    display: flex;
    gap: 0.5rem;
  }

  .carousel-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    border: none;
    background: var(--border);
    cursor: pointer;
    padding: 0;
    transition: background var(--transition);
  }

  .carousel-dot.is-active {
    background: var(--accent);
  }
</style>

<script>
  function initCarousel(root: HTMLElement) {
    const slides = Array.from(
      root.querySelectorAll<HTMLElement>(".carousel-slide"),
    );
    const dots = Array.from(
      root.querySelectorAll<HTMLElement>(".carousel-dot"),
    );
    const prevBtn = root.querySelector<HTMLButtonElement>(
      ".carousel-btn--prev",
    );
    const nextBtn = root.querySelector<HTMLButtonElement>(
      ".carousel-btn--next",
    );

    if (slides.length <= 1) return;

    let current = 0;
    let timer: ReturnType<typeof setInterval> | null = null;
    let transitioning = false;

    // ── Read config from data attributes ──────────────────────────────
    const autoScroll = root.dataset.autoScroll === "true";
    const scrollInterval = parseInt(root.dataset.scrollInterval ?? "0", 10);
    const easing = root.dataset.transitionEasing ?? "ease";
    const speedRaw = root.dataset.transitionSpeed;
    // Speed: use explicit ms value, or fall back to skin var injected below
    const speed = speedRaw ? `${speedRaw}ms` : null;

    // ── Apply CSS vars for speed / easing onto the root ───────────────
    // This lets CSS transitions pick them up without hardcoding values.
    if (speed) root.style.setProperty("--gallery-speed", speed);
    root.style.setProperty("--gallery-easing", easing);

    // ── Slide transition ───────────────────────────────────────────────
    function goTo(index: number) {
      if (transitioning) return;
      const outgoing = current;
      const incoming = (index + slides.length) % slides.length;
      if (incoming === outgoing) return;

      transitioning = true;
      const outEl = slides[outgoing];
      const inEl = slides[incoming];

      // Mark outgoing as leaving so directional CSS can apply exit transform
      outEl.classList.add("is-leaving");
      // Prepare incoming: reset transform so it starts from its CSS-defined
      // offset position, then make it active
      inEl.classList.add("is-active");
      inEl.setAttribute("aria-hidden", "false");

      dots[outgoing]?.classList.remove("is-active");
      dots[outgoing]?.setAttribute("aria-selected", "false");
      dots[incoming]?.classList.add("is-active");
      dots[incoming]?.setAttribute("aria-selected", "true");

      // After transition completes, clean up
      const cleanup = () => {
        outEl.classList.remove("is-active", "is-leaving");
        outEl.setAttribute("aria-hidden", "true");
        current = incoming;
        transitioning = false;
      };

      // Use transitionend on the incoming slide to know when done
      inEl.addEventListener("transitionend", cleanup, { once: true });
      // Safety fallback: if transitionend never fires (e.g. 'none' easing)
      // resolve after double the configured speed or 600 ms
      const fallbackMs = speedRaw ? parseInt(speedRaw, 10) * 2 : 600;
      setTimeout(() => {
        if (transitioning) cleanup();
      }, fallbackMs);
    }

    prevBtn?.addEventListener("click", () => {
      goTo(current - 1);
      resetTimer();
    });

    nextBtn?.addEventListener("click", () => {
      goTo(current + 1);
      resetTimer();
    });

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        goTo(i);
        resetTimer();
      });
    });

    function startTimer() {
      if (!autoScroll || scrollInterval <= 0) return;
      timer = setInterval(() => goTo(current + 1), scrollInterval);
    }

    function resetTimer() {
      if (timer) clearInterval(timer);
      startTimer();
    }

    // Pause on hover / focus for accessibility
    root.addEventListener("mouseenter", () => {
      if (timer) clearInterval(timer);
    });
    root.addEventListener("mouseleave", startTimer);
    root.addEventListener("focusin", () => {
      if (timer) clearInterval(timer);
    });
    root.addEventListener("focusout", startTimer);

    startTimer();
  }

  document
    .querySelectorAll<HTMLElement>(".carousel-root")
    .forEach(initCarousel);
</script>
