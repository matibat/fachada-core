---
/**
 * WidgetRenderer — application service.
 *
 * Drives page composition from a SectionConfig[] (subset of AppConfig.page.sections)
 * and a caller-provided WidgetComponentMap.
 *
 * The caller (SectionsPage.astro) statically imports all widget components and passes
 * them as the `widgetComponents` prop. WidgetRenderer iterates over enabledIds
 * (from filterSections) and looks up each section's component from the map.
 * Section IDs absent from the map are skipped with a console.warn.
 *
 * Layout variant strategy (F3 Phase A — pre-render all variants):
 *   All unique layout variants for each registered section (collected from themeLayouts
 *   across all configured themes) are pre-rendered in static HTML, each wrapped in a
 *   data-layout-section / data-layout-variant container. A dynamically generated
 *   <style is:global> block (ADR SB-2) contains the FOUC activation rules derived from
 *   the registered sections. The FOUC script in BaseLayout writes data-layout-* attributes
 *   to <html> so the correct variant is shown before first paint.
 *
 *   For sections with no themeLayouts entries, the widget renders directly without a
 *   variant wrapper — it is always visible (no CSS hide rule applies).
 *
 * RoleExplorer named exception:
 *   RoleExplorer is a React island that requires the `client:load` Astro directive.
 *   The `client:load` directive cannot be passed as a prop through WidgetComponentMap —
 *   Astro directives are special compiler annotations that cannot be expressed as
 *   JavaScript values. RoleExplorer is therefore rendered after the generic loop as an
 *   explicit named block. This is documented as ID-3 in the requirements analysis.
 *   Preferred long-term solution: move RoleExplorer handling to SectionsPage.astro
 *   (planned for the next task).
 */

import type { PageSectionConfig } from "@fachada/core";
import type { WidgetComponentMap } from "@fachada/core";
import { filterSections } from "@fachada/core";
import { resolveWidgetLayout } from "@fachada/core";
import { appConfig } from "virtual:fachada/active-app";
import { RoleExplorer } from "@fachada/core";
import { generateFoucCss } from "../../widgets/generateFoucCss.js";

export interface Props {
  /** Section configs from appConfig.page.sections. */
  sections: PageSectionConfig[];
  /** Number of entries in the 'projects' content collection. Pass 0 when absent. */
  projectsCount: number;
  /** Number of entries in the 'blog' content collection. Pass 0 when absent. */
  blogCount: number;
  /**
   * Map of section IDs to statically-imported Astro component references.
   * The caller MUST statically import every component it registers here.
   * Section IDs absent from this map are skipped with a console.warn.
   */
  widgetComponents: WidgetComponentMap;
}

const { sections, projectsCount, blogCount, widgetComponents } = Astro.props;

const enabledIds = filterSections(sections, {
  projectsCount,
  blogCount,
  availableRoles: appConfig.seo.roles.map((r) => r.id),
});

const activeStyleTheme = appConfig.themes?.default;
const themeLayouts = appConfig.themeLayouts;

// Index sections by id for O(1) layout and background lookup per widget.
const sectionMap = new Map(sections.map((s) => [s.id, s]));

/** Returns all unique layout variants for a section across every configured theme. */
function getUniqueVariants(sectionId: string): string[] {
  const variants = new Set<string>();
  if (themeLayouts) {
    for (const themeLayout of Object.values(themeLayouts)) {
      const variant = (themeLayout as Record<string, string>)[sectionId];
      if (variant) variants.add(variant);
    }
  }
  return [...variants];
}

// Build variant map for all registered enabled sections — used for FOUC CSS generation.
const sectionVariantsMap = new Map(
  enabledIds
    .filter((id) => widgetComponents[id] !== undefined)
    .map((sectionId) => [sectionId, getUniqueVariants(sectionId)] as [string, string[]])
);

// Generate per-section-per-variant FOUC activation rules (ADR SB-2).
// The static hide-all rule remains in globals.css unchanged.
const foucCss = generateFoucCss(sectionVariantsMap);
---

{foucCss && <style is:global set:html={foucCss}></style>}

{enabledIds.map((sectionId) => {
  // RoleExplorer is rendered separately below — skip it in the generic loop.
  if (sectionId === "role-explorer") return null;

  const Component = widgetComponents[sectionId];
  if (!Component) {
    console.warn(
      `[WidgetRenderer] No component registered for section: ${sectionId} — section will be skipped`
    );
    return null;
  }

  const section = sectionMap.get(sectionId);
  const variants = getUniqueVariants(sectionId);
  const resolvedLayout = resolveWidgetLayout(
    sectionId,
    section?.layout,
    themeLayouts,
    activeStyleTheme,
  );
  const bgStyle = section?.background ? `background: ${section.background}` : undefined;

  if (variants.length > 0) {
    return variants.map((variant) => (
      <div
        data-layout-section={sectionId}
        data-layout-variant={variant}
        style={bgStyle}
        aria-hidden="true"
      >
        <Component layout={variant} />
      </div>
    ));
  }

  return (
    <div style={bgStyle}>
      <Component layout={resolvedLayout} />
    </div>
  );
})}

{/*
  RoleExplorer — named exception.

  RoleExplorer is a React island that requires `client:load`. Astro client
  directives are compiler-level annotations and cannot be passed as prop values,
  so RoleExplorer cannot participate in the generic widgetComponents map.

  It is rendered here as an explicit named block, after the generic loop,
  guarded by the same enabledIds check that governs all sections. The section
  ID "role-explorer" is intentionally skipped in the loop above so it is not
  double-rendered.

  Planned: move this block to SectionsPage.astro in the next refactor task,
  eliminating the last hardcoded section reference from WidgetRenderer.
  See: analysis.md ID-3, ADR SB-1 Consequences.
*/}
{enabledIds.includes("role-explorer") && (
  <RoleExplorer
    client:load
    roles={appConfig.seo.roles}
    primaryRole={appConfig.seo.primaryRole}
  />
)}
