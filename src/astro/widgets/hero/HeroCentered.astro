---
import { siteConfig } from "../../config";
import { getActiveAppConfig } from "@fachada/core";
import Button from "../../components/ui/Button.astro";

const primaryRole =
  siteConfig.roles.find((r) => r.id === siteConfig.primaryRole) ??
  siteConfig.roles[0];
const isMultiRole = siteConfig.roles.length > 1;

const appConfig = getActiveAppConfig();
const hasHeroTransition = appConfig.navbar?.heroTransition?.enabled === true;

const isSpanish = siteConfig.lang === "es";
const primaryCtaLabel = isSpanish ? "Ver trabajo" : "View Work";
const secondaryCtaLabel = isSpanish ? "Contactar" : "Get in Touch";
---

<section
  class="hero-section-centered section-wrapper"
  data-testid="hero-section"
>
  <div class="section-inner-md text-center">
    <p
      class="hero-overline text-sm uppercase tracking-widest mb-6"
      style="color: var(--text-secondary); font-family: var(--font-mono);"
    >
      {
        isMultiRole
          ? siteConfig.roles
              .filter((r) => r.featured)
              .map((r) => r.title)
              .join(" & ")
          : primaryRole.title
      }
    </p>

    <h1
      class="font-bold mb-6 hero-title"
      data-testid="hero-title"
      data-shared-hero-brand={hasHeroTransition ? "" : undefined}
    >
      {siteConfig.name}
    </h1>

    <p
      class="text-xl md:text-2xl mb-8 max-w-2xl mx-auto"
      data-testid="hero-description"
      style="color: var(--text-secondary);"
    >
      {siteConfig.description}
    </p>

    <div class="flex-col-sm-row-centered">
      <Button
        href="#projects"
        variant="primary"
        size="lg"
        class="hero-primary-cta"
      >
        {primaryCtaLabel}
      </Button>
      <Button href="#contact" variant="outline" size="lg">
        {secondaryCtaLabel}
      </Button>
    </div>
  </div>
</section>

<style is:global>
  .hero-primary-cta {
    box-shadow: 0 8px 18px var(--shadow);
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 1.1;
  }
</style>
