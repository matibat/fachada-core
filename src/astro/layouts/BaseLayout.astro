---
import { getActiveAppConfig } from '@fachada/core';
import { LayoutWrapper } from '@fachada/core';
import { THEME_DEFINITIONS, CSS_VAR_MAP } from '@fachada/core';
import { validateThemeConfigOrThrow } from '@fachada/core';
import '../styles/globals.css';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const appConfig = getActiveAppConfig();
const siteConfig = appConfig.seo;

const {
  title = siteConfig.title,
  description = siteConfig.description,
  ogImage = siteConfig.ogImage,
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

const theme = appConfig.theme;
const appThemeVariants = appConfig.themeVariants || {};

// Validate theme configuration and get resolved theme pool for this app
const { resolvedThemes, defaultTheme: effectiveDefaultTheme } = validateThemeConfigOrThrow(appConfig, 'active-app');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImageURL} />
    
    <!-- Google Fonts — all four theme typefaces loaded upfront to avoid FOUC on switch -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;700&family=Space+Mono:wght@400;700&family=Exo+2:wght@400;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Plausible Analytics -->
    {siteConfig.analytics.plausibleDomain && (
      <script defer data-domain={siteConfig.analytics.plausibleDomain} src="https://plausible.io/js/script.js"></script>
    )}
    
    <!--
      FOUC prevention: read saved preferences from localStorage and apply the dark
      class, data-theme attribute, and all CSS custom properties synchronously
      before the first paint — before React hydrates.  CSS variables are now the
      single source of truth for all styled element colours; styled-components
      template strings reference var(--token) and therefore produce identical
      class names on server and client, eliminating the hydration mismatch.
    -->
    <script is:inline define:vars={{ defaultStyle: theme.style, defaultMode: theme.defaultMode, enableModeToggle: theme.enableModeToggle ?? true, resolvedThemesJson: JSON.stringify(resolvedThemes), cssVarMap: CSS_VAR_MAP, defaultStyleTheme: appConfig.themes?.default ?? 'minimalist', themeLayouts: appConfig.themeLayouts ?? null }}>
      (function () {
        function parseStored(raw, fallback) {
          if (!raw) return fallback;
          try { return JSON.parse(raw); } catch { return raw; }
        }

        var savedStyle = parseStored(localStorage.getItem('themeStyle'), defaultStyle);
        var savedMode  = enableModeToggle ? parseStored(localStorage.getItem('theme'), null) : null;
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

        var initialMode;
        if (savedMode && savedMode !== 'auto') {
          initialMode = savedMode;
        } else if (savedMode === 'auto' || defaultMode === 'system') {
          initialMode = prefersDark ? 'dark' : 'light';
        } else {
          initialMode = defaultMode;
        }

        // Normalise: only 'light' | 'dark' are valid token keys
        if (initialMode !== 'dark') initialMode = 'light';

        // Apply dark class (Tailwind darkMode: "class" + dark: utilities)
        document.documentElement.classList.toggle('dark', initialMode === 'dark');

        // Apply data-theme attribute (informational, for CSS attribute selectors)
        document.documentElement.setAttribute('data-theme', savedStyle);

        // Apply every CSS custom property so styled elements have the right
        // colour on the very first paint, with no flash of wrong theme.
        var themeDefinitions = JSON.parse(resolvedThemesJson);
        var styles = themeDefinitions[savedStyle];
        if (!styles) styles = themeDefinitions[defaultStyle];
        var tokens = styles && styles[initialMode];
        if (tokens) {
          var root = document.documentElement;
          for (var key in cssVarMap) {
            if (Object.prototype.hasOwnProperty.call(cssVarMap, key) && tokens[key] !== undefined) {
              root.style.setProperty(cssVarMap[key], tokens[key]);
            }
          }
        }

        // Layout variant FOUC prevention — write data-layout-<section> attributes to <html>
        // before first paint so the CSS activation rules show the correct pre-rendered variant.
        var layoutTheme = themeLayouts && (themeLayouts[savedStyle] || themeLayouts[defaultStyleTheme]);
        if (layoutTheme) {
          for (var section in layoutTheme) {
            if (Object.prototype.hasOwnProperty.call(layoutTheme, section)) {
              document.documentElement.setAttribute('data-layout-' + section, layoutTheme[section]);
            }
          }
        }
      })();
    </script>
  </head>
  <body class="min-h-screen">
    <!-- 
      Make custom themes available to client-side React components before hydration.
      This window variable is accessed by ThemeContext to resolve custom themes.
    -->
    <script is:inline define:vars={{ resolvedThemesJson: JSON.stringify(resolvedThemes), themeLayoutsJson: JSON.stringify(appConfig.themeLayouts ?? null) }}>
      window.__FACHADA_THEME_POOL__ = JSON.parse(resolvedThemesJson);
      if (themeLayoutsJson !== null) {
        window.__FACHADA_THEME_LAYOUTS__ = JSON.parse(themeLayoutsJson);
      }
    </script>

    <LayoutWrapper
      client:load
      enableModeToggle={theme.enableModeToggle}
      enableStyleSwitcher={theme.enableStyleSwitcher}
      appThemeVariants={appThemeVariants}
      defaultTheme={effectiveDefaultTheme}
      defaultColorMode={theme.defaultMode}
      appThemeGlobals={appConfig.themes?.globals ?? []}
    >
      <slot />
    </LayoutWrapper>
  </body>
</html>
