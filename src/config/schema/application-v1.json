{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Fachada Application v1 Configuration Schema",
    "description": "YAML configuration schema for Fachada v1.x applications (application.yaml)",
    "type": "object",
    "required": [
        "seo",
        "themes",
        "pages"
    ],
    "additionalProperties": false,
    "properties": {
        "seo": {
            "type": "object",
            "description": "SEO metadata and site identity",
            "required": [
                "title"
            ],
            "additionalProperties": false,
            "properties": {
                "title": {
                    "type": "string",
                    "description": "Site title"
                },
                "description": {
                    "type": "string",
                    "description": "Site meta description"
                },
                "author": {
                    "type": "string",
                    "description": "Site author name"
                },
                "author_url": {
                    "type": "string",
                    "description": "Site author URL"
                },
                "keywords": {
                    "type": "array",
                    "description": "SEO keywords",
                    "items": {
                        "type": "string"
                    }
                },
                "og_image": {
                    "type": "string",
                    "description": "Open Graph image URL"
                }
            }
        },
        "themes": {
            "type": "object",
            "description": "Theme configuration",
            "required": [
                "default"
            ],
            "additionalProperties": true,
            "properties": {
                "default": {
                    "type": "string",
                    "description": "Default theme name"
                },
                "globals": {
                    "type": "array",
                    "description": "Global theme keys to include",
                    "items": {
                        "type": "string"
                    }
                },
                "custom": {
                    "type": "object",
                    "description": "Custom theme definitions",
                    "additionalProperties": {
                        "type": "object",
                        "required": [
                            "name",
                            "light",
                            "dark"
                        ],
                        "properties": {
                            "name": {
                                "type": "string",
                                "description": "Theme name"
                            },
                            "description": {
                                "type": "string",
                                "description": "Theme description"
                            },
                            "light": {
                                "type": "object",
                                "description": "Light mode tokens",
                                "additionalProperties": true
                            },
                            "dark": {
                                "type": "object",
                                "description": "Dark mode tokens",
                                "additionalProperties": true
                            }
                        }
                    }
                }
            }
        },
        "pages": {
            "type": "object",
            "description": "Page definitions keyed by page ID",
            "additionalProperties": {
                "$ref": "#/definitions/page"
            }
        },
        "skins": {
            "type": "object",
            "description": "Global skin definitions (CSS token overrides) keyed by skin name",
            "additionalProperties": {
                "type": "object",
                "description": "Skin token overrides",
                "additionalProperties": true
            }
        },
        "assets": {
            "type": "object",
            "description": "Asset references (images, files) keyed by logical name",
            "additionalProperties": {
                "oneOf": [
                    {
                        "type": "string",
                        "description": "Asset URL or path"
                    },
                    {
                        "type": "object",
                        "description": "Theme-variant asset map",
                        "additionalProperties": {
                            "type": "string"
                        }
                    }
                ]
            }
        },
        "siteTree": {
            "type": "object",
            "description": "Site navigation tree structure",
            "additionalProperties": true
        }
    },
    "definitions": {
        "page": {
            "type": "object",
            "description": "Page configuration",
            "required": [
                "content"
            ],
            "additionalProperties": false,
            "properties": {
                "title": {
                    "type": "string",
                    "description": "Page title"
                },
                "description": {
                    "type": "string",
                    "description": "Page description"
                },
                "content": {
                    "type": "array",
                    "description": "Page content: array of widgets or containers",
                    "items": {
                        "oneOf": [
                            {
                                "$ref": "#/definitions/widget"
                            },
                            {
                                "$ref": "#/definitions/container"
                            }
                        ]
                    }
                },
                "skin": {
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "object"
                        }
                    ],
                    "description": "Page-level skin (name or token overrides). Overrides site-level skin."
                },
                "translations": {
                    "type": "object",
                    "description": "Per-page translations keyed by language code",
                    "additionalProperties": {
                        "type": "object",
                        "description": "Language-specific string map",
                        "additionalProperties": {
                            "type": "string"
                        }
                    }
                },
                "tags": {
                    "type": "array",
                    "description": "Page tags",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "widget": {
            "type": "object",
            "description": "Widget (leaf component)",
            "required": [
                "type"
            ],
            "additionalProperties": false,
            "properties": {
                "type": {
                    "type": "string",
                    "description": "Widget type (component registry key)"
                },
                "props": {
                    "type": "object",
                    "description": "Widget props (arbitrary schema per widget)",
                    "additionalProperties": true
                },
                "skin": {
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "object"
                        }
                    ],
                    "description": "Widget-level skin (name or token overrides). Overrides page/site skin."
                }
            }
        },
        "container": {
            "type": "object",
            "description": "Container (grouping element with layout and optional children). Supports unlimited nesting.",
            "required": [
                "type"
            ],
            "additionalProperties": false,
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "container"
                    ],
                    "description": "Container type marker"
                },
                "layout": {
                    "type": "string",
                    "description": "Layout type (grid, flex, stack, etc.)"
                },
                "props": {
                    "type": "object",
                    "description": "Container props (layout configuration)",
                    "additionalProperties": true
                },
                "children": {
                    "type": "array",
                    "description": "Child widgets or containers (recursive, unlimited nesting depth)",
                    "items": {
                        "oneOf": [
                            {
                                "$ref": "#/definitions/widget"
                            },
                            {
                                "$ref": "#/definitions/container"
                            }
                        ]
                    }
                },
                "skin": {
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "object"
                        }
                    ],
                    "description": "Container-level skin (name or token overrides). Overrides page/site skin."
                }
            }
        }
    }
}