{
    "name": "@fachada/core",
    "version": "0.1.0",
    "type": "module",
    "description": "The core of the Fachada framework",
    "keywords": [
        "portfolio",
        "framework",
        "web page",
        "spa",
        "static site",
        "fachada"
    ],
    "author": "Matías Batista <matibat@gmail.com>",
    "license": "GPL-3.0-or-later",
    "bin": {
        "create-fachada-app": "./dist/cli/create-app.js"
    },
    "exports": {
        ".": "./dist/index.js",
        "./astro": "./dist/astro/integration.js",
        "./vite": "./dist/vite/fachada-plugin.js"
    },
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "peerDependencies": {
        "astro": ">=4.0.0",
        "react": ">=18.0.0",
        "react-dom": ">=18.0.0",
        "styled-components": ">=5.0.0",
        "zustand": ">=4.0.0"
    },
    "scripts": {
        "build": "tsc -p tsconfig.build.json && find src/astro -name '*.astro' -o -name '*.css' | while read f; do dest=\"dist/astro/${f#src/astro/}\"; mkdir -p \"$(dirname \"$dest\")\"; cp \"$f\" \"$dest\"; done",
        "prepare": "npm run build",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "devDependencies": {
        "@astrojs/react": "^5.0.3",
        "@testing-library/dom": "^10.0.0",
        "@testing-library/react": "^16.0.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^4.0.0",
        "@vitest/coverage-v8": "^2.1.8",
        "astro": "^6.1.5",
        "happy-dom": "^20.0.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "typescript": "^6.0.2",
        "vitest": "^2.1.8",
        "zustand": "^5.0.12"
    },
    "dependencies": {
        "zod": "^4.3.6"
    },
    "publishConfig": {
        "access": "public"
    }
}
